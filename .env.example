# Copy this to .env.local and fill in real values.
# Get these from https://supabase.com/dashboard/project/<your-project>/settings/api

# Safe to expose to the browser (used by the public Supabase client)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. Never expose this in client code or commit it.
# Used for migrations and admin server actions.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# The canonical URL of the deployed app — used for magic-link redirects.
# Locally: http://localhost:3000
# In Vercel Production: https://travelston.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend — transactional email provider for send.travelston.com.
# Magic-link auth emails are sent by Supabase, but routed through Resend's
# SMTP creds (configured in Supabase Dashboard → Auth → SMTP Settings).
# This key is only needed in app code if/when we add direct transactional
# sends (announcements, RSVP nudges, etc.) — leave unset until then.
# RESEND_API_KEY=

# Sentry (#68b) — leave unset locally to disable client/server reporting
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Upstash rate-limit (#68c, provisioned via Vercel Marketplace in #124).
#
# Production uses the Vercel-Marketplace "Upstash for Redis" auto-injection,
# which populates KV_REST_API_URL / KV_REST_API_TOKEN (Vercel's KV-naming
# convention). The rate-limit module accepts EITHER pair — the KV_* names
# (preferred, what `vercel env pull` returns on this project after #124) or
# the legacy UPSTASH_* names (still supported for direct-Upstash setups).
#
# Leaving all four unset locally is fine — the in-memory shim takes over
# with a loud warning. Provision via `vercel env pull` to get the real
# limiter against the prod Upstash instance.
KV_REST_API_URL=
KV_REST_API_TOKEN=
# Legacy / direct-Upstash naming, accepted as fallback:
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Magic-link redirect origin (#71 / PR #102 security fix-up).
# `NEXT_PUBLIC_SITE_URL` above is used to build the server-side
# `emailRedirectTo` Supabase sees when issuing magic links. Setting it
# explicitly (rather than deriving the origin from request headers)
# prevents an open-redirect via spoofed `x-forwarded-host` /
# `x-forwarded-proto`. On Vercel, preview deploys can fall back to
# `VERCEL_URL` (auto-populated by the platform), so leaving the var
# unset on previews is acceptable.
